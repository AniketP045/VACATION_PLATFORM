<!-- SUCCESS FLASH -->
<% if (success && success.length) { %>
  <div class="alert alert-success alert-dismissible fade show flash-alert mb-3" role="alert">
    <i class="fa-solid fa-circle-check me-1"></i> <%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<!-- ERROR FLASH -->
<% if (error && error.length) { %>
  <div class="alert alert-danger alert-dismissible fade show flash-alert mb-3" role="alert">
    <i class="fa-solid fa-circle-exclamation me-1"></i> <%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>
<style>
  .flash-alert {
    animation: slideDown 0.35s ease;
    border-radius: 10px;
    box-shadow: 0 4px 14px rgba(0,0,0,0.15);
  }

  @keyframes slideDown {
    from { transform: translateY(-12px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
</style>
<script>
  setTimeout(() => {
    const alert = document.querySelector('.flash-alert');
    if (alert) {
      const bsAlert = new bootstrap.Alert(alert);
      bsAlert.close();
    }
  }, 3000);
</script>
