<% layout('admin/layout', { title: 'Dashboard', admin }) %>

<div class="container py-4">
  <h3 class="mb-4">Admin Dashboard</h3>
  <div class="row g-4">

    <!-- TOTAL USERS -->
    <div class="col-md-4">
      <div class="card shadow-sm border-0 rounded-3 dashboard-card">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <h6 class="text-uppercase text-muted mb-1">Total Users</h6>
            <h2 class="fw-bold"><%= usersCount %></h2>
          </div>
          <div class="icon-box bg-primary text-white">
            <i class="bi bi-people-fill"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- TOTAL LISTINGS -->
    <div class="col-md-4">
      <div class="card shadow-sm border-0 rounded-3 dashboard-card">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <h6 class="text-uppercase text-muted mb-1">Total Listings</h6>
            <h2 class="fw-bold"><%= listingsCount %></h2>
          </div>
          <div class="icon-box bg-success text-white">
            <i class="bi bi-card-list"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- PENDING LISTINGS -->
    <div class="col-md-4">
      <div class="card shadow-sm border-0 rounded-3 dashboard-card">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <h6 class="text-uppercase text-muted mb-1">Pending Listings</h6>
            <h2 class="fw-bold"><%= pendingCount %></h2>
          </div>
          <div class="icon-box bg-warning text-dark">
            <i class="bi bi-hourglass-split"></i>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<style>
  .dashboard-card {
    transition: 0.2s ease;
  }
  .dashboard-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.1);
  }
  .icon-box {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 28px;
  }
</style>