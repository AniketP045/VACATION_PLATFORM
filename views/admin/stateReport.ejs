<% layout('admin/layout', { title: 'State Report' , admin }) %>

  <div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h3 class="mb-0">State-wise Listing Report</h3>
        <small class="text-muted">See how many listings are created in each state.</small>
      </div>
      <a href="/admin/reports/state/download" class="btn btn-sm btn-success">
        <i class="bi bi-download"></i> Download as CSV
      </a>
    </div>

    <div class="card shadow-sm">
      <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th style="width:60px">#</th>
              <th>State</th>
              <th>Listings (names)</th>
              <th style="width:160px" class="text-end">Total Listings</th>
            </tr>
          </thead>

          <tbody>
            <% if (!stateReport || stateReport.length===0) { %>
              <tr>
                <td colspan="4" class="text-center py-4 text-muted">
                  No data available yet.
                </td>
              </tr>
              <% } else { %>
                <% stateReport.forEach(function(row, index){ %>
                  <tr>
                    <td>
                      <%= index + 1 %>
                    </td>

                    <!-- State name -->
                    <td>
                      <%= row._id || "Not specified" %>
                    </td>

                    <!-- ✅ त्या state मधल्या listing names ची list -->
                    <td>
                      <% if (row.listings && row.listings.length) { %>
                        <ul class="mb-0">
                          <% row.listings.forEach(function(l){ %>
                            <li>
                              <a href="/listings/<%= l._id %>" target="_blank">
                                <%= l.title || "Untitled" %>
                              </a>
                            </li>
                            <% }); %>
                        </ul>
                        <% } else { %>
                          <span class="text-muted">No listings</span>
                          <% } %>
                    </td>

                    <!-- Total count -->
                    <td class="text-end fw-semibold">
                      <%= row.totalListings %>
                    </td>
                  </tr>
                  <% }); %>
                    <% } %>
          </tbody>

        </table>
      </div>
    </div>
  </div>